{
  "name": "pourkit",
  "private": true,
  "type": "module",
  "workspaces": [
    "pourkit",
    "common/logger"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:agent": "CI_AGENT=true npm run build --workspace pourkit",
    "dev": "echo 'No dev server. Use `npm run pourkit` to run the CLI.'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:agent": "CI_AGENT=true vitest run",
    "typecheck": "npm run typecheck --workspaces",
    "pourkit": "npm run build --workspace pourkit && node pourkit/dist/cli.js",
    "pourkit:auto": "npm run pourkit -- queue-run --target default",
    "pourkit:prd": "npm run pourkit -- queue-run --target PRD",
    "pourkit:issue": "npm run pourkit -- issue",
    "pourkit:unblock": "npm run build --workspace pourkit && node pourkit/dist/unblock.js",
    "pourkit:close-issues-on-merge": "npm run build --workspace pourkit && node pourkit/dist/issues/close-issues-on-merge.js",
    "pourkit:e2e": "npm run build --workspace pourkit && node pourkit/dist/e2e/run-live-e2e.js",
    "pourkit:e2e:cleanup": "npm run pourkit:e2e -- --cleanup-only",
    "pourkit:e2e:full": "npm run pourkit:e2e -- --full-check",
    "pourkit:e2e:test-live": "npm run build && npm run typecheck && npm run test && bash pourkit/e2e/test-live.sh",
    "package:smoke": "npm run build --workspace pourkit && POURKIT_PACKAGE_SMOKE=true vitest run pourkit/package-smoke.test.ts",
    "pourkit:e2e:test-all-live": "npm run pourkit:e2e:test-live --target=$npm_config_target -- pourkit/e2e/live/*.test.ts",
    "prettier:check": "prettier --ignore-unknown --check .",
    "prettier:write": "prettier --ignore-unknown --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.6.3",
    "@types/node": "^25.6.2",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "esbuild": "0.28.0"
  }
}
