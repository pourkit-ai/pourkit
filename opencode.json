{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "pourkit-architect": {
      "mode": "primary",
      "description": "Primary orchestration agent for Pourkit architectural lifecycle management. Owns initiative continuity, exploration routing, compression, roadmap evolution, PRD orchestration, issue orchestration, reconciliation, and drift prevention.",
      "reasoningEffort": "high",
      "temperature": 0.2,
      "model": "openai/gpt-5.5",
      "prompt": "{file:.pourkit/prompts/pourkit-architect.prompt.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "edit": "allow",
        "bash": {
          "*": "deny"
        },
        "task": {
          "*": "deny",
          "pourkit-architecture-compressor": "allow",
          "pourkit-architecture-reconciler": "allow",
          "pourkit-prd-publisher": "allow",
          "pourkit-issue-publisher": "allow",
          "advisory-analyzer": "allow"
        }
      }
    },

    "pourkit-builder": {
      "mode": "primary",
      "hidden": true,
      "description": "Implements Pourkit issues as the Builder role.",
      "reasoningEffort": "high",
      "temperature": 0.2,
      "permission": {
        "task": {
          "*": "deny",
          "advisory-analyzer": "allow"
        }
      }
    },

    "pourkit-reviewer": {
      "mode": "primary",
      "hidden": true,
      "description": "Produces authoritative Pourkit Reviewer artifacts.",
      "permission": {
        "task": "deny"
      }
    },

    "pourkit-refactor": {
      "mode": "primary",
      "hidden": true,
      "reasoningEffort": "max",
      "temperature": 0.1,
      "description": "Addresses Pourkit Reviewer findings as the Refactor role.",
      "permission": {
        "task": {
          "*": "deny",
          "advisory-analyzer": "allow"
        }
      }
    },

    "pourkit-pr-description": {
      "mode": "primary",
      "hidden": true,
      "reasoningEffort": "high",
      "temperature": 0.1,
      "description": "Writes Pourkit PR description artifacts.",
      "permission": {
        "task": "deny"
      }
    },

    "pourkit-architecture-compressor": {
      "mode": "subagent",
      "hidden": true,
      "description": "Compresses large architectural exploration sessions into durable initiative state under .pourkit/architecture.",
      "reasoningEffort": "medium",
      "temperature": 0.1,
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:.pourkit/prompts/pourkit-architecture-compressor.prompt.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "allow",
        "bash": {
          "*": "deny"
        },
        "task": "deny"
      }
    },

    "pourkit-architecture-reconciler": {
      "mode": "subagent",
      "hidden": true,
      "description": "Reconciles completed PRDs/issues against initiative roadmap, locked decisions, and architectural state.",
      "reasoningEffort": "medium",
      "temperature": 0.1,
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:.pourkit/prompts/pourkit-architecture-reconciler.prompt.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "allow",
        "bash": {
          "*": "deny"
        },
        "task": "deny"
      }
    },

    "pourkit-prd-publisher": {
      "mode": "subagent",
      "hidden": true,
      "description": "Publishes one Architect-selected PRD to GitHub and mirrors the exact body under .pourkit/architecture.",
      "reasoningEffort": "medium",
      "temperature": 0.1,
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:.pourkit/prompts/pourkit-prd-publisher.prompt.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "task": "deny"
      }
    },

    "pourkit-issue-publisher": {
      "mode": "subagent",
      "hidden": true,
      "description": "Publishes child Issues for one Architect-selected PRD and mirrors exact bodies under .pourkit/architecture.",
      "reasoningEffort": "medium",
      "temperature": 0.1,
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:.pourkit/prompts/pourkit-issue-publisher.prompt.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "task": "deny"
      }
    },

    "advisory-analyzer": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Provides bounded advisory analysis for Pourkit Builder, Refactor, and Architect.",
      "prompt": "{file:.pourkit/prompts/advisory-analyzer.prompt.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "deny",
        "task": "deny"
      }
    }
  }
}
